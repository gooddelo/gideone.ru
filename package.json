		"@types/eslint": "^8.56.7",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.36.0",
		"prettier": "^3.2.5",
		"prettier-plugin-svelte": "^3.2.2",
		"sass": "^1.74.1",
		"svelte": "^4.2.12",
		"svelte-check": "^3.6.9",
		"svelte-preprocess": "^5.1.3",
		"typescript": "^5.4.4",
		"vite": "^5.2.8"
	},
	"type": "module",
	"dependencies": {
